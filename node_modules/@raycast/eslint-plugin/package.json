{
  "name": "@raycast/eslint-plugin",
  "version": "2.2.0",
  "description": "ESLint plugin designed to help Raycast's extensions authors follow best practices",
  "author": "Raycast Technologies Ltd.",
  "keywords": [
    "raycast",
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "api.js",
    "api.d.ts",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc",
    "type:check": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --ci",
    "preupdate:docs": "npm run build",
    "update:docs": "eslint-doc-generator",
    "lint": "npm-run-all \"lint:*\"",
    "lint:eslint-docs": "npm-run-all \"update:docs -- --check\"",
    "lint:ts": "eslint .",
    "prepublish": "npm run build"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.62.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.62.0",
    "@typescript-eslint/rule-tester": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-doc-generator": "^3.6.0",
    "eslint-plugin-eslint-plugin": "^7.4.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.5",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.11"
  },
  "peerDependencies": {
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0"
  }
}
